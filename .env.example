# ===== Supabase (yo hago todo con el access token) =====
# Generar en: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxx

# ===== Clerk (crear app en dashboard.clerk.com y copiar de API Keys) =====
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx

# ===== Resend (crear en https://resend.com/api-keys) =====
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ===== Vercel (opcional si prefieres no hacer `vercel login`) =====
# Generar en: https://vercel.com/account/settings/tokens
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
